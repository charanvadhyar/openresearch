    "# Load data\n",
    "data_path = None\n",
    "for root, dirs, files in os.walk('/kaggle/input'):\n",
    "    for f in files:\n",
    "        if f.endswith('.csv'):\n",
    "            data_path = os.path.join(root, f)\n",
    "            break\n",
    "    if data_path: break\n",
    "\n",
    "df = pd.read_csv(data_path)\n",
    "print(f'Loaded: {df.shape[0]:,} rows × {df.shape[1]} columns')\n",
    "print(f'Target stats: mean={df[TARGET_COL].mean():.3f}, std={df[TARGET_COL].std():.3f}')"
   ]
  },
