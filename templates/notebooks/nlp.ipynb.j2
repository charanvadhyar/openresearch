    "# Load data\n",
    "data_path = None\n",
    "for root, dirs, files in os.walk('/kaggle/input'):\n",
    "    for f in files:\n",
    "        if f.endswith('.csv'): data_path = os.path.join(root, f); break\n",
    "    if data_path: break\n",
    "df = pd.read_csv(data_path)\n",
    "# Auto-detect text column if not specified\n",
    "if TEXT_COL not in df.columns:\n",
    "    text_candidates = df.select_dtypes(include='object').columns\n",
    "    TEXT_COL = max(text_candidates, key=lambda c: df[c].str.len().mean())\n",
    "    print(f'Auto-detected text column: {TEXT_COL}')\n",
    "print(f'{df.shape[0]:,} rows | Classes: {df[TARGET_COL].nunique()}')"
